{
  "name": "linear-korean-helper",
  "version": "0.1.0",
  "description": "Korean UI Helper for Linear — Linear의 주요 UI 용어를 한국어로 보조 표시하는 Chrome Extension",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "dev:popup": "vite build --watch --mode popup-dev",
    "build": "vite build && vite build --mode popup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "jsdom": "^24.0.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0"
  }
}
