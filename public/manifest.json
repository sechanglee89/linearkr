{
  "manifest_version": 3,
  "name": "LinearKR - Korean UI Helper",
  "version": "0.1.0",
  "description": "Unofficial Korean UI helper for Linear.",
  "permissions": ["storage"],
  "host_permissions": ["https://linear.app/*"],
  "content_scripts": [
    {
      "matches": ["https://linear.app/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LinearKR - Korean UI Helper"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
